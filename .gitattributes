# Auto-detect text files and normalise line endings
* text=auto

# C++ source
*.cpp   text diff=cpp
*.h     text diff=cpp
*.hpp   text diff=cpp

# Makefiles
*.mk    text
*.cmake text

# Scripts
*.sh    text eol=lf

# Configuration
*.prop  text
*.yml   text
*.yaml  text
*.json  text
*.ini   text
*.cfg   text
*.conf  text

# Documentation
*.md    text diff=markdown
*.txt   text

# Git files
.gitattributes text
.gitignore     text

# Binary files
*.so   binary
*.zip  binary
*.png  binary
*.jpg  binary
*.ico  binary
*.woff2 binary

# Build outputs
libs/  -text
obj/   -text
